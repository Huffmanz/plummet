; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Plummet"
run/main_scene="res://scenes/run/run_controller.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

TransitionManager="*res://scenes/autoload/transition_manager.tscn"
DataRegistry="*res://scripts/data/data_registry.gd"
GameCursor="*res://scripts/ui/game_cursor.gd"
GameTooltip="*res://scripts/ui/game_tooltip.gd"
MusicPlayer="*res://scenes/autoload/music_player.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=3840
window/size/window_height_override=2160
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="uid://edpcy4cdwgv"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=3
rendering_device/driver.windows="d3d12"
